# ============================================
# SPARSH - School Result Analysis System
# Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values.

# --- Application Core ---
PROJECT_NAME="School Result Analysis System"
API_V1_STR="/api/v1"

# --- Security ---
SECRET_KEY="CHANGE_THIS_TO_A_RANDOM_SECRET_KEY"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
# SQLite (local development):
DATABASE_URL="sqlite:///./sras_local.db"
# PostgreSQL (production — e.g. Neon, Render):
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Storage ---
STORAGE_PROVIDER="local"
REPORT_STORAGE_DIR="./report_storage"

# Fernet key for encrypting OAuth tokens in the database.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=""

# --- Google OAuth 2.0 (for Google Drive integration) ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Leave empty to disable Google Drive integration.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://127.0.0.1:8000/api/v1/settings/storage/oauth/callback"

# --- Google Picker API Key (separate from OAuth) ---
# Create an API Key at: Cloud Console → Credentials → API Key
# Restrict it to the Picker API and your domain via HTTP referrer.
# Leave empty to disable the folder picker (admin will paste folder URL instead).
GOOGLE_PICKER_API_KEY=""

# --- Default Admin Seed ---
DEFAULT_ADMIN_USERNAME="admin"
DEFAULT_ADMIN_PASSWORD="admin123"
DEFAULT_ADMIN_FULLNAME="System Administrator"

